# ── Data Protection keys (machine-local, must not be committed) ───────────────
.data-protection-keys/

# ── Build outputs ─────────────────────────────────────────────────────────────
bin/
obj/
out/
publish/

# ── NuGet ─────────────────────────────────────────────────────────────────────
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.fragment.lock.json

# ── Visual Studio ─────────────────────────────────────────────────────────────
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# ── ReSharper ─────────────────────────────────────────────────────────────────
_ReSharper*/
*.DotSettings.user
.resharper/

# ── Rider ─────────────────────────────────────────────────────────────────────
.idea/
*.sln.iml

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# ── dotnet test / coverage ────────────────────────────────────────────────────
TestResults/
coverage/
*.coverage
*.coveragexml
*.trx
BenchmarkDotNet.Artifacts/

# ── Publish profiles ──────────────────────────────────────────────────────────
**/Properties/PublishProfiles/

# ── Secrets & environment ─────────────────────────────────────────────────────
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json
*.env
.env
secrets.json
# .NET user secrets (stored outside repo at %APPDATA%\Microsoft\UserSecrets\)
# — listed here as a reminder; they are never inside the repo

# ── Certificates & private keys (never commit these) ──────────────────────────
*.pfx
*.p12
*.pem
*.key
*.crt
*.cer
*.csr

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temporary files ───────────────────────────────────────────────────────────
*.tmp
*.temp
~$*

# ── Angular / Node ────────────────────────────────────────────────────────────
admin-ui/node_modules/
admin-ui/dist/
admin-ui/.angular/
admin-ui/.cache/
admin-ui/.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
# Local environment overrides (environment.ts and environment.prod.ts are committed;
# a developer-local override should never be)
admin-ui/src/environments/environment.local.ts
