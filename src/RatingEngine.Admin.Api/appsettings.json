{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/admin-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "tenant-acme": "Server=acme-sql.example.com;Database=RatingEngine;User Id=app;Password=CHANGE_ME;"
  },
  "IdentityServer": {
    "Authority": "https://localhost:7000",
    "AdminApiClientId": "rating-engine-admin-api",
    "AdminApiClientSecret": "rating-engine-admin-introspection-secret"
  },
  "Security": {
    "RequireAuth": false
  }
}
