{
  "productCode": "CONDO-IL",
  "coverageCode": "BUILDINGCVG",
  "version": "2026.02",
  "effectiveStart": "2026-02-01",
  "perils": ["GRP1", "GRP2", "SPL"],
  "pipeline": [

    { "id": "S1_GRP1_BASERATE", "name": "Grp I Base Rate",
      "operation": "lookup", "rateTable": "CondoBaseRate",
      "keys": { "ConstructionType": "$risk.ConstructionType", "BuildingClass": "$risk.BuildingClass", "OccupancyType": "$risk.OccupancyType" },
      "math": { "type": "set" },
      "when": { "path": "$peril", "equals": "GRP1" } },

    { "id": "S1_GRP2_BASERATE", "name": "Grp II Base Rate",
      "operation": "lookup", "rateTable": "CondoGRP2BaseRate",
      "keys": { "Territory": "$risk.Territory", "ConstructionType": "$risk.ConstructionType", "BuildingClass": "$risk.BuildingClass" },
      "math": { "type": "set" },
      "when": { "path": "$peril", "equals": "GRP2" } },

    { "id": "S1_SPL_BASERATE", "name": "SPL Base Rate",
      "operation": "lookup", "rateTable": "CondoSPLBaseRate",
      "keys": { "Wildcard": "*" },
      "math": { "type": "set" },
      "when": { "path": "$peril", "equals": "SPL" } },

    { "id": "S2_LCM", "name": "Loss Cost Multiplier",
      "operation": "lookup", "rateTable": "CondoLCM",
      "keys": { "LCMTier": "$risk.LCMTier" },
      "math": { "type": "mul" } },

    { "id": "S3_GRP1_TERRFACTOR", "name": "Territory Factor",
      "operation": "lookup", "rateTable": "CondoTerritoryFactor",
      "keys": { "Territory": "$risk.Territory" },
      "math": { "type": "mul" },
      "when": { "path": "$peril", "equals": "GRP1" } },

    { "id": "S3_SPL_TERRFACTOR", "name": "SPL Territory Factor",
      "operation": "lookup", "rateTable": "CondoSPLTerritoryFactor",
      "keys": { "Territory": "$risk.Territory" },
      "math": { "type": "mul" },
      "when": { "path": "$peril", "equals": "SPL" } },

    { "id": "S4_GRP1_PPCFACTOR", "name": "Protection Class Factor",
      "operation": "lookup", "rateTable": "CondoPPCFactor",
      "keys": { "ConstructionType": "$risk.ConstructionType", "PPC": "$risk.PPC" },
      "math": { "type": "mul" },
      "when": { "path": "$peril", "equals": "GRP1" } },

    { "id": "S4_GRP2_BCEG", "name": "BCEG Factor",
      "operation": "lookup", "rateTable": "CondoGRP2BCEG",
      "keys": { "Wildcard": "*" },
      "math": { "type": "mul" },
      "when": { "path": "$peril", "equals": "GRP2" } },

    { "id": "S5_GRP1_COINSFACTOR", "name": "Coinsurance Factor",
      "operation": "lookup", "rateTable": "CondoCoinsuranceFactor",
      "keys": { "CoinsuranceCode": "$coverage.CoinsuranceCode" },
      "math": { "type": "mul" },
      "when": { "path": "$peril", "equals": "GRP1" } },

    { "id": "S5_GRP2SPL_COINSFACTOR", "name": "Coinsurance Factor",
      "operation": "lookup", "rateTable": "CondoGRP2CoinsFactor",
      "keys": { "CoinsuranceCode": "$coverage.CoinsuranceCode" },
      "math": { "type": "mul" },
      "when": { "path": "$peril", "in": "GRP2,SPL" } },

    { "id": "S6_GRP1_LOIFACTOR", "name": "Limit of Insurance Factor",
      "operation": "lookup", "rateTable": "CondoLOIFactor",
      "keys": { "ConstructionType": "$risk.ConstructionType", "InsuredValue": "$coverage.InsuredValue" },
      "math": { "type": "mul" },
      "interpolate": { "key": "InsuredValue" },
      "when": { "path": "$peril", "equals": "GRP1" } },

    { "id": "S6_GRP2_LOIFACTOR", "name": "Grp II Limit of Insurance Factor",
      "operation": "lookup", "rateTable": "CondoGRP2LOIFactor",
      "keys": { "InsuredValue": "$coverage.InsuredValue" },
      "math": { "type": "mul" },
      "interpolate": { "key": "InsuredValue" },
      "when": { "path": "$peril", "equals": "GRP2" } },

    { "id": "S6_SPL_LOIFACTOR", "name": "SPL Limit of Insurance Factor",
      "operation": "lookup", "rateTable": "CondoSPLLOIFactor",
      "keys": { "InsuredValue": "$coverage.InsuredValue" },
      "math": { "type": "mul" },
      "interpolate": { "key": "InsuredValue" },
      "when": { "path": "$peril", "equals": "SPL" } },

    { "id": "S7_GRP1_DEDFACTOR", "name": "Deductible Factor",
      "operation": "lookup", "rateTable": "CondoDedFactor",
      "keys": { "Deductible": "$coverage.Deductible" },
      "rangeKey": { "key": "InsuredValue" },
      "math": { "type": "mul" },
      "when": { "path": "$peril", "equals": "GRP1" } },

    { "id": "S7_GRP2SPL_DEDFACTOR", "name": "Deductible Factor",
      "operation": "lookup", "rateTable": "CondoGRP2DedFactor",
      "keys": { "Deductible": "$coverage.Deductible" },
      "rangeKey": { "key": "InsuredValue" },
      "math": { "type": "mul" },
      "when": { "path": "$peril", "in": "GRP2,SPL" } },

    { "id": "S8_WHAILDED", "name": "Wind/Hail Deductible",
      "operation": "lookup", "rateTable": "CondoWindHailDedFactor",
      "keys": { "WindHailDedCode": "$coverage.WindHailDedCode" },
      "rangeKey": { "key": "InsuredValue" },
      "math": { "type": "mul" },
      "when": { "path": "$coverage.WindHailDedCode", "notEquals": "" } },

    { "id": "S9_UNITDED", "name": "Per Unit Deductible",
      "operation": "lookup", "rateTable": "CondoUnitDedFactor",
      "keys": { "Wildcard": "*" },
      "math": { "type": "mul" },
      "when": { "path": "$coverage.HasUnitDeductible", "isTrue": "true" } },

    { "id": "S10_RULE83", "name": "Rule 83",
      "operation": "lookup", "rateTable": "CondoRule83",
      "keys": { "Wildcard": "*" },
      "math": { "type": "mul" },
      "when": { "path": "$coverage.ApplyRule83", "isTrue": "true" } },

    { "id": "ROUND_RATE", "operation": "round",
      "round": { "precision": 8, "mode": "AwayFromZero" } },

    { "id": "S11_VALUEM", "name": "Valuation Factor",
      "operation": "lookup", "rateTable": "CondoValuationFactor",
      "keys": { "ValuationMethod": "$risk.ValuationMethod" },
      "math": { "type": "mul" } },

    { "id": "S12_FINALPREM", "name": "Apply Building Limit (per $100)",
      "operation": "compute",
      "compute": { "expr": "$premium * $coverage.InsuredValue / 100", "storeAs": "FinalRate", "applyToPremium": true } },

    { "id": "ROUND_FINAL", "operation": "round",
      "round": { "precision": 2, "mode": "AwayFromZero" } }
  ]
}
