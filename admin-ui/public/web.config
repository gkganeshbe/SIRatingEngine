<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!--
      Angular SPA routing: any path that is not a real file or directory
      must be rewritten to index.html so the Angular router handles it.
      Requires the IIS URL Rewrite module to be installed.
    -->
    <rewrite>
      <rules>
        <rule name="Angular SPA" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <!-- Skip real files (JS bundles, CSS, assets) -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile"      negate="true" />
            <!-- Skip real directories -->
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- Serve compressed responses for JS/CSS bundles -->
    <httpCompression>
      <dynamicTypes>
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="text/css"               enabled="true" />
      </dynamicTypes>
      <staticTypes>
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="text/css"               enabled="true" />
      </staticTypes>
    </httpCompression>

    <!-- Cache hashed bundles for 1 year; never cache index.html -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>

    <httpProtocol>
      <customHeaders>
        <!-- Prevent index.html from being cached by browsers -->
        <remove name="Cache-Control" />
      </customHeaders>
    </httpProtocol>

    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin" />
        </hiddenSegments>
      </requestFiltering>
    </security>

  </system.webServer>

  <!--
    Location-specific rule: ensure index.html is never cached
    so users always get the latest app after a redeployment.
  -->
  <location path="index.html">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
          <add name="Pragma"        value="no-cache" />
          <add name="Expires"       value="0" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

</configuration>
