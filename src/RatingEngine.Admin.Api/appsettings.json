{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/admin-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "MasterDb": "Host=localhost;Database=MasterDB;Username=postgres;Password=CHANGE_ME;"
  },
  "IdentityServer": {
    "Authority": "http://localhost:7000",
    "AdminApiClientId": "rating-engine-admin-api",
    "AdminApiClientSecret": "rating-engine-admin-introspection-secret",
    "ManagementClientId": "rating-engine-management",
    "ManagementClientSecret": "CHANGE_ME",
    "ManagementScope": "user.management"
  },
  "Security": {
    "RequireAuth": true
  }
}
